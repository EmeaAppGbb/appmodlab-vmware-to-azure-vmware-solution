          "network": "10.10.20.0/24",
          "dhcpConfig": {
            "resourceType": "SegmentDhcpV4Config",
            "serverAddress": "10.10.20.2/24",
            "leaseTime": 86400,
            "dhcpRanges": ["10.10.20.10-10.10.20.200"],
            "dnsServers": ["10.10.30.11", "168.63.129.16"],
            "options": {
              "option121": {
                "staticRoutes": [
                  {
                    "network": "0.0.0.0/0",
                    "nextHop": "10.10.20.1"
                  }
                ]
              }
            }
          }
        }
      ],
      "tags": [
        {"scope": "environment", "tag": "production"},
        {"scope": "tier", "tag": "app"},
        {"scope": "application", "tag": "harbor-retail"}
